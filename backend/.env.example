# ============================================================
# 反诈人生 · 后端环境变量模板（M1.4 统一密钥管理）
# 使用方法：复制本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略，切勿提交。
# ============================================================

# ---------- 混元大模型（OpenAI 兼容接口） ----------
# 从 https://console.cloud.tencent.com/hunyuan 获取
HUNYUAN_API_KEY=your-api-key-here
# 混元 API Base URL（OpenAI 兼容格式）
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1/
# 使用的模型
HUNYUAN_MODEL=hunyuan-turbos-latest

# ---------- AI 生成参数 ----------
AI_TEMPERATURE=0.9
AI_TOP_P=0.9
AI_MAX_TOKENS=500

# ---------- 服务 ----------
PORT=3000

# ---------- 统一入口鉴权（小程序 / H5 共用，M1.4） ----------
# 前端调用后端 /api/* 时携带的访问令牌；留空表示不校验（仅本地开发）。
# 生产环境务必设置为强随机值，前端通过统一入口注入。
API_ACCESS_TOKEN=
# 允许的跨域来源（逗号分隔）；* 表示放开（仅开发环境使用）
CORS_ORIGIN=*

# ---------- 内容安全护栏（M1.1） ----------
# 是否开启对话审计日志（写入 backend/logs/chat-audit.log，供每日人工抽检）
SAFETY_AUDIT_ENABLED=true
